from sklearn.preprocessing import StandardScaler, OneHotEncoder 
from sklearn.compose import ColumnTransformer 


df.columns





X = df.drop('price', axis= 1) 
y = df['price']





y_log = np.log1p(y)


y_log


# identify column types 
# categorical : text-based or zip codes 
categorical_features = ['city', 'statezip'] 


# numerical : everything else (including yr_built and binary flag like is_renovated) 
numeric_features = ['bedrooms', 'bathrooms', 'sqft_living', 'sqft_lot', 'floors', 
                    'waterfront', 'view', 'condition', 'yr_built', 'is_renovated']





preprocessor = ColumnTransformer(
    transformers= [
        ('num', StandardScaler(), numeric_features), 
        ('cat', OneHotEncoder(handle_unknown= 'ignore', sparse_output= False), categorical_features)
    ]
) 


# apply the transformation  
X_processed = preprocessor.fit_transform(X) 





encoded_cat_names = preprocessor.named_transformers_['cat'].get_feature_names_out(categorical_features)
all_feature_names = numeric_features + list(encoded_cat_names)
X_final_df = pd.DataFrame(X_processed, columns=all_feature_names) 

print("Target transformed and features processed successfully!")
print(f"New feature count: {X_processed.shape[1]}")


X_final_df.shape 








from sklearn.model_selection import train_test_split
X_train, X_test, y_train, y_test = train_test_split(X_processed, y_log, test_size= 0.2, random_state= 42) 


print(f'Training data on X : {X_train.shape}')
print(f'Training data on y : {y_train.shape}')
print('-----------------------------------')
print(f'Testing data on X : {X_test.shape}')
print(f'Testing data on y : {y_test.shape}')





from sklearn.linear_model import LinearRegression 
model = LinearRegression() 
model.fit(X_train, y_train) 

y_pred_log = model.predict(X_test)
print('Model Training Complete !')





from sklearn.metrics import mean_squared_error, r2_score


r2 = r2_score(y_test, y_pred_log) 
rmse = np.sqrt(mean_squared_error(y_test, y_pred_log)) 

print(f'R-sqared score : {r2:.4f}')
print(f'RMSE (Log scale) : {rmse:.4f}')





from sklearn.metrics import mean_absolute_error
# 1. Reverse the log transformation for both actual and predicted values
y_test_actual = np.expm1(y_test)      # Converts log back to real price
y_pred_actual = np.expm1(y_pred_log)  # Converts log prediction back to real price

# 2. Calculate the average error in DOLLARS
avg_error_dollars = mean_absolute_error(y_test_actual, y_pred_actual)

print(f"Log Scale Error: 0.16") # This is what you see now
print(f"Real World Average Error: ${avg_error_dollars:,.2f}")


plt.figure(figsize=(8, 6))
sns.scatterplot(x=y_test_actual, y=y_pred_actual, alpha=0.5)

# Add a diagonal line for 'Perfect Prediction'
line_coords = [y_test_actual.min(), y_test_actual.max()]
plt.plot(line_coords, line_coords, color='red', linestyle='--')

plt.xlabel('Actual Price ($)')
plt.ylabel('Predicted Price ($)')
plt.title('Actual vs Predicted House Prices')








new_house_data = {
    'bedrooms': 3,
    'bathrooms': 2.5,
    'sqft_living': 2500,
    'sqft_lot': 5000,
    'floors': 2,
    'waterfront': 0,      # 1 if yes, 0 if no
    'view': 0,            # 0 (none) to 4 (great)
    'condition': 3,       # 1 (worn out) to 5 (excellent)
    'yr_built': 1995,
    'city': 'Seattle',
    'statezip': 'WA 98103',
    'is_renovated': 0     # 1 if yes, 0 if no
}


input_df = pd.DataFrame([new_house_data])
input_df





input_processed = preprocessor.transform(input_df)


predicted_double_log = model.predict(input_processed)[0]
# Step 1: remove outer log1p
log_price = np.expm1(predicted_double_log)


# Step 2: remove inner log
actual_price = np.exp(log_price)


print("="*30)
print("HOUSE PRICE PREDICTION")
print("="*30)
print(f"Predicted market value: ${actual_price:,.2f}")
print("="*30)








import pickle 

with open('house_model.pkl', 'wb') as f: 
    pickle.dump({'model': model, 'preprocessor': preprocessor}, f) 

print('Model saved sucessfully as house_model.pkl')



