df['price'] = np.log(df['price'])


# checking the target distribution 
sns.histplot(df['price'], kde= True) 
plt.title("Target distribution of price")


df.isna().sum() 


df.columns





numeric_data = df.select_dtypes(include= [np.number])
categorical_data = df.select_dtypes(exclude= [np.number])


numeric_data.columns


categorical_data.columns





# drop absolute useless columns
df.drop(['country', 'street', 'date'], axis= 1, inplace= True)
# Address multicollinearity (Keeping total living area)
df.drop(['sqft_above', 'sqft_basement'], axis= 1, inplace= True) 
# cleaning the target variable (remove 0dollar prices) 
df = df[df['price'] > 0]


# convert yr_renovated to a binary 0 or 1 (was it renovated or not ?)
df['is_renovated'] = df['yr_renovated'].apply(lambda x: 1 if x > 0 else 0)
df.drop('yr_renovated', axis= 1, inplace= True) 





Q1 = df['price'].quantile(0.25)
Q3 = df['price'].quantile(0.75)
IQR = Q3 - Q1 

print(f'Q1 : {Q1} \nQ3 : {Q3}')

lower_bound = Q1 - 1.5*IQR 
upper_bound = Q3 + 1.5*IQR 

print(f'Lower bound : {lower_bound} \nUpper bound : {upper_bound}')


sns.boxplot(df['price']) 
plt.title("Target distribution of price")





# keep only the data within the bounds 
df_filtered = df[(df['price'] >= 11.644) & (df['price']<= 14.447)]


